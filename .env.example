# Database
# For development, SQLite is used (file-based, no server needed)
# For production, consider PostgreSQL
DATABASE_URL="file:./dev.db"

# College Scorecard API (Optional)
# Get a free API key at: https://api.data.gov/signup/
# DEMO_KEY works but has lower rate limits
COLLEGE_SCORECARD_API_KEY=DEMO_KEY

# Production Database Example (PostgreSQL)
# Uncomment and update for production deployment
# DATABASE_URL="postgresql://username:password@localhost:5432/university_app"

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/
