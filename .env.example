# Database
# For development, SQLite is used (file-based, no server needed)
# For production, consider PostgreSQL
DATABASE_URL="file:./dev.db"

# College Scorecard API (Optional)
# Get a free API key at: https://api.data.gov/signup/
# DEMO_KEY works but has lower rate limits
COLLEGE_SCORECARD_API_KEY=DEMO_KEY

